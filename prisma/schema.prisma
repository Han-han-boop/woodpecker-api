generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InviteCodeStatus {
  active
  revoked
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  blocks    Block[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InviteCode {
  id        String           @id @default(uuid())
  code      String           @unique
  status    InviteCodeStatus @default(active)
  uses      Int              @default(0)
  maxUses   Int?
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Block {
  id            String            @id @default(cuid())
  ownerId       String
  owner         User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  symbol        String
  sessionCount  Int               @default(100)
  templates     SessionTemplate[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model SessionCatalog {
  id          String   @id @default(cuid())
  symbol      String
  serie       String
  sessionDate String
  state       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([symbol, serie])
}

model SessionTemplate {
  id            String       @id
  blockId       String
  block         Block        @relation(fields: [blockId], references: [id], onDelete: Cascade)
  sessionNumber Int
  date          String?
  sessionType   String       @default("custom")
  serie         String?
  m1Url         String?
  m15Url        String?
  h4Url         String?
  h4Url1        String?
  h4Url2        String?
  h4Url3        String?
  runs          SessionRun[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([blockId, sessionNumber])
}

model SessionRun {
  id           String        @id
  templateId   String
  template     SessionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  runIndex     Int
  startedAt    DateTime
  endedAt      DateTime?
  result       String?
  sumR         Float?
  trades         Trade[]
  journalEntries JournalEntry[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([templateId, runIndex])
}

model Trade {
  id         String     @id @default(cuid())
  runId      String
  run        SessionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  direction  String
  entryTsUtc DateTime
  entryPrice Float
  slPrice    Float?
  tpPrice    Float?
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([runId])
}

model JournalEntry {
  id         String       @id @default(cuid())
  runId      String
  run        SessionRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  title      String?
  notesMd    String?
  reviewJson Json?
  result     String?
  sumR       Float?
  discipline Int?
  confidence Int?
  tags       JournalTag[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([runId])
}

model JournalTag {
  id        String       @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag       String
  createdAt DateTime     @default(now())

  @@unique([entryId, tag])
  @@index([entryId])
}
